{
  "expo": {
    "name": "D-CLOCK",
    "slug": "dclock-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "dclock",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5F1EB"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.d99tech.dclock",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "D-CLOCK necesita tu ubicación para validar que estás en la zona de trabajo al registrar tu asistencia.",
        "NSLocationAlwaysUsageDescription": "D-CLOCK necesita tu ubicación para validar que estás en la zona de trabajo.",
        "NSCameraUsageDescription": "D-CLOCK toma una foto para verificar tu identidad al registrar la asistencia.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F1EB"
      },
      "package": "com.d99tech.dclock",
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "D-CLOCK necesita tu ubicación para validar la zona de trabajo."
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "D-CLOCK toma una foto para verificar tu identidad al registrar la asistencia."
        }
      ],
      "expo-secure-store",
      "expo-font",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0d7e2fa8-64b4-42aa-bbf0-f048a6ad73bf"
      }
    },
    "owner": "aalmaguer"
  }
}
